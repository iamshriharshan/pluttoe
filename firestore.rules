rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create, update: if signedIn() && request.auth.uid == userId;
    }

    match /freelancers/{freelancerId} {
      allow read: if signedIn();
      allow create, update: if signedIn() && request.auth.uid == freelancerId;
    }

    match /startups/{startupId} {
      allow read: if signedIn();
      allow create, update: if signedIn() && request.auth.uid == startupId;
    }

    match /opportunities/{opportunityId} {
      allow read: if signedIn();
      allow create: if signedIn() &&
        request.resource.data.startupId == request.auth.uid;
      allow update, delete: if signedIn() &&
        resource.data.startupId == request.auth.uid;
    }

    match /applications/{applicationId} {
      allow read: if signedIn();
      allow create: if signedIn() &&
        request.resource.data.freelancerId == request.auth.uid;
      allow update: if signedIn() &&
        resource.data.startupId == request.auth.uid;
      allow delete: if false;
    }

    match /messages/{messageId} {
      allow read: if signedIn() &&
        (
          resource.data.freelancerId == request.auth.uid ||
          resource.data.startupId == request.auth.uid
        );
      allow create: if signedIn() &&
        (
          request.resource.data.freelancerId == request.auth.uid ||
          request.resource.data.startupId == request.auth.uid
        ) &&
        (
          get(/databases/$(database)/documents/applications/$(request.resource.data.applicationId)).data.status == "chat_approved" ||
          get(/databases/$(database)/documents/applications/$(request.resource.data.applicationId)).data.status == "approved"
        );
      allow update, delete: if false;
    }

    match /ai_recommendations/{recommendationId} {
      allow read: if signedIn();
      allow create: if signedIn() &&
        request.resource.data.startupId == request.auth.uid;
      allow update: if signedIn() &&
        resource.data.startupId == request.auth.uid;
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
